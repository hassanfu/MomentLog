# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── DeepSeek（简报：OpenAI 兼容接口，国内可用）─────────────────
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...
# 部署到 Vercel：在网页里加同名变量，或本机已 `npx vercel link` 后运行
# npm run vercel:push-deepseek （把本地 .env.local 同步到 Production/Preview/Development）

# ── Resend（简报「发邮件」：API Key 必填；发件地址可选）──────────
# https://resend.com/api-keys → 创建 RESEND_API_KEY（以 re_ 开头）
# https://resend.com/domains → 验证域名后配置发件人
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL 须满足 Resend 格式，任选其一（不要加引号、不要换行）：
#   仅邮箱：noreply@你的域名.com
#   或：MomentLog <noreply@你的域名.com>  （发件邮箱须为已验证域名下的地址）
# 同步到 Vercel（需已 vercel link）：npm run vercel:push-resend

# ── Site URL (for OAuth redirect) ────────────────────────────
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
